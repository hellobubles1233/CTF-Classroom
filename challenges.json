[
  {
    "id": "md-01",
    "category": "markdown",
    "level": "basic",
    "title": "Markdown-Datei erstellen",
    "brief": "Erstelle Markdown.md in deinem Markdown-Arbeitsbereich.",
    "hint": "Erstelle die Datei in workspaces/{user}/markdown/Markdown.md.",
    "guide": [
      "Ordner erstellen: workspaces/{user}/markdown",
      "Datei erstellen: workspaces/{user}/markdown/Markdown.md"
    ],
    "checks": [
      {
        "type": "path_exists",
        "path": "workspaces/{user}/markdown/Markdown.md",
        "kind": "file"
      }
    ],
    "points": 10
  },
  {
    "id": "md-02",
    "category": "markdown",
    "level": "intermediate",
    "title": "Überschriften und Listen",
    "brief": "Füge H1-H6, eine Aufzählung und eine nummerierte Liste mit Unterpunkten hinzu.",
    "hint": "Nutze # bis ###### sowie - und 1. mit eingerückten Unterpunkten.",
    "guide": [
      "Bearbeite workspaces/{user}/markdown/Markdown.md",
      "Füge Überschriften H1 bis H6 ein",
      "Füge eine Aufzählungsliste ein",
      "Füge eine nummerierte Liste mit mindestens einem Unterpunkt ein"
    ],
    "checks": [
      {
        "type": "file_contains_regex",
        "path": "workspaces/{user}/markdown/Markdown.md",
        "regex": "^#\\s+.+",
        "flags": "m"
      },
      {
        "type": "file_contains_regex",
        "path": "workspaces/{user}/markdown/Markdown.md",
        "regex": "^##\\s+.+",
        "flags": "m"
      },
      {
        "type": "file_contains_regex",
        "path": "workspaces/{user}/markdown/Markdown.md",
        "regex": "^###\\s+.+",
        "flags": "m"
      },
      {
        "type": "file_contains_regex",
        "path": "workspaces/{user}/markdown/Markdown.md",
        "regex": "^####\\s+.+",
        "flags": "m"
      },
      {
        "type": "file_contains_regex",
        "path": "workspaces/{user}/markdown/Markdown.md",
        "regex": "^#####\\s+.+",
        "flags": "m"
      },
      {
        "type": "file_contains_regex",
        "path": "workspaces/{user}/markdown/Markdown.md",
        "regex": "^######\\s+.+",
        "flags": "m"
      },
      {
        "type": "file_contains_regex",
        "path": "workspaces/{user}/markdown/Markdown.md",
        "regex": "^-\\s+.+",
        "flags": "m"
      },
      {
        "type": "file_contains_regex",
        "path": "workspaces/{user}/markdown/Markdown.md",
        "regex": "^\\d+\\.\\s+.+",
        "flags": "m"
      },
      {
        "type": "file_contains_regex",
        "path": "workspaces/{user}/markdown/Markdown.md",
        "regex": "^[ \\t]{2,}[-*]\\s+.+",
        "flags": "m"
      }
    ],
    "points": 15
  },
  {
    "id": "md-03",
    "category": "markdown",
    "level": "intermediate",
    "title": "Callout und PowerShell-Block",
    "brief": "Füge eine Callout-Zeile und einen PowerShell-Codeblock mit Hello World ein.",
    "hint": "Nutze > für Callout und ```powershell für den Block.",
    "guide": [
      "Bearbeite workspaces/{user}/markdown/Markdown.md",
      "Füge eine Callout-Zeile ein, die mit > startet",
      "Füge einen powershell-Codeblock ein",
      "Nutze Hello World im powershell-Block"
    ],
    "checks": [
      {
        "type": "file_contains_regex",
        "path": "workspaces/{user}/markdown/Markdown.md",
        "regex": "^>\\s+.+",
        "flags": "m"
      },
      {
        "type": "file_contains",
        "path": "workspaces/{user}/markdown/Markdown.md",
        "text": "```powershell"
      },
      {
        "type": "file_contains_regex",
        "path": "workspaces/{user}/markdown/Markdown.md",
        "regex": "hello\\s+world",
        "flags": "i"
      }
    ],
    "points": 15
  },
  {
    "id": "md-04",
    "category": "markdown",
    "level": "basic",
    "title": "Klickbarer Link",
    "brief": "Füge mindestens einen klickbaren Markdown-Link ein.",
    "hint": "Verwende [Text](https://beispiel.de).",
    "guide": [
      "Bearbeite workspaces/{user}/markdown/Markdown.md",
      "Füge einen klickbaren Markdown-Link ein"
    ],
    "checks": [
      {
        "type": "file_contains_regex",
        "path": "workspaces/{user}/markdown/Markdown.md",
        "regex": "\\[[^\\]]+\\]\\(https?:\\/\\/[^)]+\\)",
        "flags": ""
      }
    ],
    "points": 10
  },
  {
    "id": "md-05",
    "category": "markdown",
    "level": "basic",
    "title": "Bild einbetten",
    "brief": "Füge ein eingebettetes Markdown-Bild ein.",
    "hint": "Verwende ![Alt-Text](https://beispiel.de/bild.png).",
    "guide": [
      "Bearbeite workspaces/{user}/markdown/Markdown.md",
      "Füge ein Markdown-Bild ein"
    ],
    "checks": [
      {
        "type": "file_contains_regex",
        "path": "workspaces/{user}/markdown/Markdown.md",
        "regex": "!\\[[^\\]]*\\]\\([^)]+\\)",
        "flags": ""
      }
    ],
    "points": 10
  },
  {
    "id": "md-06",
    "category": "markdown",
    "level": "intermediate",
    "title": "Markdown-Tabelle",
    "brief": "Füge eine Tabelle mit Kopfzeile, Trennzeile und Datenzeile ein.",
    "hint": "Nutze die Pipe-Syntax für Tabellen.",
    "guide": [
      "Bearbeite workspaces/{user}/markdown/Markdown.md",
      "Füge eine Tabellen-Kopfzeile mit mindestens zwei Spalten ein",
      "Füge eine Trennzeile ein",
      "Füge mindestens eine Datenzeile ein"
    ],
    "checks": [
      {
        "type": "file_contains_regex",
        "path": "workspaces/{user}/markdown/Markdown.md",
        "regex": "\\|[^\\n]+\\|[^\\n]+\\|\\n\\|\\s*[-:]+\\s*\\|\\s*[-:]+\\s*\\|\\n\\|[^\\n]+\\|[^\\n]+\\|",
        "flags": "m"
      }
    ],
    "points": 15
  },
  {
    "id": "unix-01",
    "category": "unix",
    "level": "basic",
    "title": "Ordnerstruktur bauen",
    "brief": "Erstelle einen Ordner und eine Datei im korrekten Pfad.",
    "hint": "Nutze mkdir -p, cd und touch.",
    "guide": [
      "Run: mkdir -p workspaces/{user}/unix-basics/notes",
      "Run: cd workspaces/{user}/unix-basics/notes",
      "Run: touch intro.txt"
    ],
    "checks": [
      {
        "type": "path_exists",
        "path": "workspaces/{user}/unix-basics/notes",
        "kind": "dir"
      },
      {
        "type": "path_exists",
        "path": "workspaces/{user}/unix-basics/notes/intro.txt",
        "kind": "file"
      },
      {
        "type": "command_logged",
        "regex": "mkdir\\s+-p\\s+workspaces/.+/unix-basics/notes"
      }
    ],
    "points": 15
  },
  {
    "id": "unix-02",
    "category": "unix",
    "level": "intermediate",
    "title": "Umbenennen und Echo",
    "brief": "Benenne eine Datei um und schreibe eine Zeile hinein.",
    "hint": "Nutze mv und echo \"text\" > datei.",
    "guide": [
      "Run: mv workspaces/{user}/unix-basics/notes/intro.txt workspaces/{user}/unix-basics/notes/welcome.txt",
      "Run: echo \"Linux powers teams\" > workspaces/{user}/unix-basics/notes/welcome.txt"
    ],
    "checks": [
      {
        "type": "path_missing",
        "path": "workspaces/{user}/unix-basics/notes/intro.txt"
      },
      {
        "type": "path_exists",
        "path": "workspaces/{user}/unix-basics/notes/welcome.txt",
        "kind": "file"
      },
      {
        "type": "file_contains",
        "path": "workspaces/{user}/unix-basics/notes/welcome.txt",
        "text": "Linux powers teams"
      },
      {
        "type": "command_logged",
        "regex": "mv\\s+workspaces/.+/intro.txt\\s+workspaces/.+/welcome.txt"
      }
    ],
    "points": 20
  },
  {
    "id": "unix-03",
    "category": "unix",
    "level": "advanced",
    "title": "Pipeline-Profi",
    "brief": "Nutze eine Pipeline, um Zeilen zu zählen und zu speichern.",
    "hint": "cat datei | wc -l > count.txt",
    "guide": [
      "Erstelle die Datei workspaces/{user}/unix-basics/notes/log.txt mit mindestens 3 Zeilen",
      "Run: cat workspaces/{user}/unix-basics/notes/log.txt | wc -l > workspaces/{user}/unix-basics/notes/count.txt"
    ],
    "checks": [
      {
        "type": "path_exists",
        "path": "workspaces/{user}/unix-basics/notes/count.txt",
        "kind": "file"
      },
      {
        "type": "file_contains_regex",
        "path": "workspaces/{user}/unix-basics/notes/count.txt",
        "regex": "\\d+",
        "flags": ""
      },
      {
        "type": "command_logged",
        "regex": "\\|\\s*wc\\s+-l"
      }
    ],
    "points": 25
  },
  {
    "id": "git-01",
    "category": "git",
    "level": "basic",
    "title": "Init und erster Commit",
    "brief": "Erstelle ein Git-Repo mit erstem Commit im Workspace.",
    "hint": "git init, git add, git commit -m.",
    "guide": [
      "Run: mkdir -p workspaces/{user}/git-lab",
      "Run im Repo: git init",
      "Erstelle die Datei NOTES.md mit einer Zeile",
      "Run: git add NOTES.md",
      "Run: git commit -m \"chore: first commit\""
    ],
    "checks": [
      {
        "type": "path_exists",
        "path": "workspaces/{user}/git-lab/.git",
        "kind": "dir"
      },
      {
        "type": "git_commit_count_min",
        "repo": "workspaces/{user}/git-lab",
        "min": 1
      },
      {
        "type": "git_commit_message_regex",
        "repo": "workspaces/{user}/git-lab",
        "regex": "chore:\\s+first commit"
      }
    ],
    "points": 20
  },
  {
    "id": "git-02",
    "category": "git",
    "level": "intermediate",
    "title": "Branch-Workflow",
    "brief": "Erstelle einen Feature-Branch und committe darauf.",
    "hint": "git checkout -b feature/<name>",
    "guide": [
      "Erstelle im Repo workspaces/{user}/git-lab den Branch feature/docs",
      "Füge die Datei BRANCH.md hinzu",
      "Committe mit: feat: add branch file"
    ],
    "checks": [
      {
        "type": "git_branch_exists",
        "repo": "workspaces/{user}/git-lab",
        "branch": "feature/docs"
      },
      {
        "type": "path_exists",
        "path": "workspaces/{user}/git-lab/BRANCH.md",
        "kind": "file"
      },
      {
        "type": "git_commit_message_regex",
        "repo": "workspaces/{user}/git-lab",
        "regex": "feat:\\s+add branch file"
      }
    ],
    "points": 25
  },
  {
    "id": "git-03",
    "category": "git",
    "level": "advanced",
    "title": "Zurück mergen",
    "brief": "Merge feature/docs in main mit einem Merge-Commit.",
    "hint": "Wechsle auf main und führe git merge --no-ff feature/docs aus.",
    "guide": [
      "Wechsle auf main in workspaces/{user}/git-lab",
      "Run: git merge --no-ff feature/docs -m \"merge: feature/docs\""
    ],
    "checks": [
      {
        "type": "git_commit_message_regex",
        "repo": "workspaces/{user}/git-lab",
        "regex": "merge:\\s+feature/docs"
      },
      {
        "type": "command_logged",
        "regex": "git\\s+merge\\s+--no-ff\\s+feature/docs"
      }
    ],
    "points": 30
  },
  {
    "id": "boss-01",
    "category": "mixed",
    "level": "advanced",
    "title": "Release-Notes Boss",
    "brief": "Erstelle Release Notes in Markdown und committe sie mit Git.",
    "hint": "Kombiniere mkdir, echo/cat, Markdown-Überschriften und git commit.",
    "guide": [
      "Erstelle die Datei workspaces/{user}/git-lab/docs/RELEASE_NOTES.md",
      "Füge die Überschrift # Release Notes und mindestens einen Bullet hinzu",
      "Committe mit: docs: add release notes"
    ],
    "checks": [
      {
        "type": "path_exists",
        "path": "workspaces/{user}/git-lab/docs/RELEASE_NOTES.md",
        "kind": "file"
      },
      {
        "type": "file_contains_regex",
        "path": "workspaces/{user}/git-lab/docs/RELEASE_NOTES.md",
        "regex": "^#\\s+Release Notes",
        "flags": "m"
      },
      {
        "type": "file_contains_regex",
        "path": "workspaces/{user}/git-lab/docs/RELEASE_NOTES.md",
        "regex": "^- .+",
        "flags": "m"
      },
      {
        "type": "git_commit_message_regex",
        "repo": "workspaces/{user}/git-lab",
        "regex": "docs:\\s+add release notes"
      }
    ],
    "points": 40
  }
]
